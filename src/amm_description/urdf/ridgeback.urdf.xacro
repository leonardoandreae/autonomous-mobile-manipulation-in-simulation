<?xml version="1.0"?>
<!--
  Minimal Clearpath Ridgeback description for AMM simulation.
  Matches the link/joint names expected by the mecanum drive plugin
  and by amm_description (mid_mount attachment point).

  Physical properties based on the Ridgeback datasheet:
    Chassis:        960 x 793 x 164 mm
    Wheelbase:      476 mm  (front–rear axle distance)
    Track width:    476 mm  (left–right wheel centre distance)
    Wheel radius:    87.5 mm
    Total mass:     ~100 kg (with arm, use 60 kg for base)
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ridgeback">

  <!-- ── Constants ──────────────────────────────────────────────────────────── -->
  <xacro:property name="PI"             value="3.14159265358979"/>
  <xacro:property name="chassis_length" value="0.960"/>
  <xacro:property name="chassis_width"  value="0.793"/>
  <xacro:property name="chassis_height" value="0.164"/>
  <xacro:property name="chassis_mass"   value="60.0"/>
  <xacro:property name="wheel_radius"   value="0.0875"/>
  <xacro:property name="wheel_width"    value="0.060"/>
  <xacro:property name="wheel_mass"     value="1.5"/>
  <xacro:property name="wheelbase"      value="0.476"/>   <!-- front–rear -->
  <xacro:property name="track"          value="0.476"/>   <!-- left–right -->
  <!-- Z-offset so wheels rest on ground (z=0) -->
  <xacro:property name="wheel_z"        value="${wheel_radius}"/>

  <!-- ── Inertia helpers ────────────────────────────────────────────────────── -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12}" ixy="0" ixz="0"
               iyy="${m*(x*x+z*z)/12}" iyz="0"
               izz="${m*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cyl_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- ── base_footprint ────────────────────────────────────────────────────── -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_z}" rpy="0 0 0"/>
  </joint>

  <!-- ── base_link (chassis) ───────────────────────────────────────────────── -->
  <link name="base_link">
    <xacro:box_inertia m="${chassis_mass}"
                       x="${chassis_length}"
                       y="${chassis_width}"
                       z="${chassis_height}"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="ridgeback_yellow">
        <color rgba="0.95 0.75 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
  </link>

  <!-- ── mid_mount — arm attachment point (top centre of chassis) ──────────── -->
  <link name="mid_mount"/>
  <joint name="mid_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="mid_mount"/>
    <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ── front_mount / rear_mount (convenience frames) ────────────────────── -->
  <link name="front_mount"/>
  <joint name="front_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="front_mount"/>
    <origin xyz="${chassis_length/2} 0 ${chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <link name="rear_mount"/>
  <joint name="rear_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="rear_mount"/>
    <origin xyz="${-chassis_length/2} 0 ${chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ── Wheel macro ────────────────────────────────────────────────────────── -->
  <!--
    Mecanum rollers are approximated as cylinders for collision.
    The wheel is oriented with its spin axis along Y (ROS convention).
    x_reflect: +1 = front, -1 = rear
    y_reflect: +1 = left,  -1 = right
  -->
  <xacro:macro name="mecanum_wheel" params="name x_reflect y_reflect">
    <link name="${name}">
      <xacro:cyl_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="wheel_dark">
          <color rgba="0.15 0.15 0.15 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}"/>
      <origin xyz="${x_reflect * wheelbase/2}
                   ${y_reflect * (track/2 + wheel_width/2)}
                   ${-chassis_height/2}"
              rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>
  </xacro:macro>

  <xacro:mecanum_wheel name="front_left_wheel"  x_reflect=" 1" y_reflect=" 1"/>
  <xacro:mecanum_wheel name="front_right_wheel" x_reflect=" 1" y_reflect="-1"/>
  <xacro:mecanum_wheel name="rear_left_wheel"   x_reflect="-1" y_reflect=" 1"/>
  <xacro:mecanum_wheel name="rear_right_wheel"  x_reflect="-1" y_reflect="-1"/>

</robot>
