<?xml version="1.0"?>
<!--
  ridgeback_franka.urdf.xacro
  ============================
  Combines the Clearpath Ridgeback omnidirectional mobile base with the
  Franka FR3 7-DoF arm mounted on the top plate.

  Arguments:
    use_gazebo   (default false) — include Gazebo Harmonic plugins
    sim_gazebo   (default false) — alias, same effect

  Dependencies (must be installed / cloned into your workspace):
    - ridgeback_description   (ros-jazzy-ridgeback-description or from source)
    - franka_description      (from franka_ros2, Jazzy branch)

  Usage:
    ros2 launch amm_description description.launch.py
    xacro ridgeback_franka.urdf.xacro use_gazebo:=true
-->

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ridgeback_franka">

  <!-- ── Arguments ─────────────────────────────────────────────────────────── -->
  <xacro:arg name="use_gazebo"  default="false"/>
  <xacro:arg name="sim_gazebo"  default="false"/>

  <!-- ── Ridgeback base ──────────────────────────────────────────────────────── -->
  <xacro:include filename="$(find ridgeback_description)/urdf/ridgeback.urdf.xacro"/>

  <!-- ── Franka FR3 arm ─────────────────────────────────────────────────────── -->
  <xacro:include filename="$(find franka_description)/robots/fr3/fr3.urdf.xacro"/>

  <!-- ── Mount the arm on the Ridgeback top plate ───────────────────────────── -->
  <joint name="ridgeback_to_fr3" type="fixed">
    <parent link="mid_mount"/>
    <child  link="fr3_link0"/>
    <origin xyz="0.0 0.0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- ── Franka Hand (parallel gripper) ────────────────────────────────────── -->
  <!-- Included as part of fr3.urdf.xacro above.  TCP: fr3_hand_tcp            -->

  <!-- ══════════════════════════════════════════════════════════════════════════
       GAZEBO HARMONIC PLUGINS
       Only included when use_gazebo:=true or sim_gazebo:=true.
       ══════════════════════════════════════════════════════════════════════════ -->
  <xacro:if value="$(eval '$(arg use_gazebo)' == 'true' or '$(arg sim_gazebo)' == 'true')">

    <!-- ── gz_ros2_control — arm + gripper joints ──────────────────────────── -->
    <gazebo>
      <plugin filename="gz_ros2_control-system"
              name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>$(find amm_bringup)/config/manipulation.yaml</parameters>
        <ros>
          <namespace>/</namespace>
        </ros>
      </plugin>
    </gazebo>

    <!-- ── Mecanum drive controller — Ridgeback base ───────────────────────── -->
    <!--
      The mecanum_drive_controller plugin drives the four mecanum wheels by
      reading /cmd_vel (geometry_msgs/Twist) and publishing /odom.
      Wheel joint names must match ridgeback_description.
    -->
    <gazebo>
      <plugin filename="gz-sim-mecanum-drive-system"
              name="gz::sim::systems::MecanumDrive">
        <front_left_joint>front_left_wheel</front_left_joint>
        <front_right_joint>front_right_wheel</front_right_joint>
        <rear_left_joint>rear_left_wheel</rear_left_joint>
        <rear_right_joint>rear_right_wheel</rear_right_wheel>
        <wheel_separation>0.476</wheel_separation>
        <wheelbase>0.476</wheelbase>
        <wheel_radius>0.0875</wheel_radius>
        <min_acceleration>-5</min_acceleration>
        <max_acceleration>5</max_acceleration>
        <topic>cmd_vel</topic>
        <odom_topic>odom</odom_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
        <odom_publish_frequency>50</odom_publish_frequency>
      </plugin>
    </gazebo>

    <!-- ── 2D LiDAR ─────────────────────────────────────────────────────────── -->
    <!--
      Mounted on the Ridgeback front; publishes sensor_msgs/LaserScan.
      Bridged to /scan via ros_gz_bridge.
    -->
    <link name="lidar_link">
      <visual>
        <geometry><cylinder radius="0.04" length="0.05"/></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient></material>
      </visual>
      <collision>
        <geometry><cylinder radius="0.04" length="0.05"/></geometry>
      </collision>
      <inertial>
        <mass>0.1</mass>
        <inertia><ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>0.0001</iyy><iyz>0</iyz><izz>0.0001</izz></inertia>
      </inertial>
    </link>
    <joint name="lidar_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="lidar_link"/>
      <origin xyz="0.3 0.0 0.3" rpy="0 0 0"/>
    </joint>

    <gazebo reference="lidar_link">
      <sensor name="lidar" type="gpu_lidar">
        <update_rate>15</update_rate>
        <topic>lidar/scan</topic>
        <gz_frame_id>lidar_link</gz_frame_id>
        <ray>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.1</min>
            <max>30.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise>
        </ray>
        <always_on>true</always_on>
        <visualize>false</visualize>
      </sensor>
    </gazebo>

    <!-- ── RGB-D camera (wrist-mounted) ──────────────────────────────────────── -->
    <!--
      Mounted on the arm's end-effector link for manipulation perception.
      Publishes image + depth + point cloud.
      Bridged via ros_gz_bridge.
    -->
    <link name="camera_link">
      <visual>
        <geometry><box size="0.04 0.10 0.04"/></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient></material>
      </visual>
      <collision>
        <geometry><box size="0.04 0.10 0.04"/></geometry>
      </collision>
      <inertial>
        <mass>0.1</mass>
        <inertia><ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>0.0001</iyy><iyz>0</iyz><izz>0.0001</izz></inertia>
      </inertial>
    </link>
    <joint name="camera_joint" type="fixed">
      <parent link="fr3_hand"/>
      <child  link="camera_link"/>
      <origin xyz="0.0 0.0 0.10" rpy="0 0.3 0"/>
    </joint>

    <link name="camera_optical_frame"/>
    <joint name="camera_optical_joint" type="fixed">
      <parent link="camera_link"/>
      <child  link="camera_optical_frame"/>
      <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    </joint>

    <gazebo reference="camera_link">
      <sensor name="rgbd_camera" type="rgbd_camera">
        <update_rate>30</update_rate>
        <topic>camera</topic>
        <gz_frame_id>camera_optical_frame</gz_frame_id>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>RGB_INT8</format>
          </image>
          <clip><near>0.1</near><far>10.0</far></clip>
          <depth_camera>
            <clip><near>0.1</near><far>10.0</far></clip>
          </depth_camera>
          <noise><type>gaussian</type><mean>0</mean><stddev>0.007</stddev></noise>
        </camera>
        <always_on>true</always_on>
        <visualize>false</visualize>
      </sensor>
    </gazebo>

    <!-- ── IMU ────────────────────────────────────────────────────────────────── -->
    <link name="imu_link">
      <inertial>
        <mass>0.01</mass>
        <inertia><ixx>0.00001</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>0.00001</iyy><iyz>0</iyz><izz>0.00001</izz></inertia>
      </inertial>
    </link>
    <joint name="imu_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="imu_link"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </joint>

    <gazebo reference="imu_link">
      <sensor name="imu_sensor" type="imu">
        <update_rate>200</update_rate>
        <topic>imu/data</topic>
        <gz_frame_id>imu_link</gz_frame_id>
        <always_on>true</always_on>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.0004</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.0004</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.0004</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
    </gazebo>

  </xacro:if>

</robot>
